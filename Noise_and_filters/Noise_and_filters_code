"""
Noise Modeling and Filtering in Images

This script demonstrates:
- Salt & Pepper noise
- Gaussian noise
- Median filtering
- Mean filtering
"""

import numpy as np
import matplotlib.pyplot as plt
import cv2
import os


# -----------------------------
# Utility Functions
# -----------------------------

def load_image(path):
    """Load image in grayscale"""
    img = cv2.imread(path, cv2.IMREAD_GRAYSCALE)
    return img.astype(np.float32)


def save_image(path, image):
    """Save image to file"""
    image = np.clip(image, 0, 255)
    cv2.imwrite(path, image.astype(np.uint8))


# -----------------------------
# Noise Functions
# -----------------------------

def salt_pepper_noise(image, probability=0.05):
    """Add salt and pepper noise"""
    noisy = np.copy(image)
    rand = np.random.rand(*image.shape)

    noisy[rand < probability / 2] = 0
    noisy[rand > 1 - probability / 2] = 255

    return noisy


def gaussian_noise(image, mean=0, sigma=10):
    """Add Gaussian noise"""
    noise = np.random.normal(mean, sigma, image.shape)
    noisy = image + noise
    return noisy


# -----------------------------
# Filtering Functions
# -----------------------------

def median_filter(image, kernel_size=3):
    """Apply median filter"""
    pad = kernel_size // 2
    padded = np.pad(image, pad, mode='edge')
    filtered = np.zeros_like(image)

    for i in range(image.shape[0]):
        for j in range(image.shape[1]):
            window = padded[i:i+kernel_size, j:j+kernel_size]
            filtered[i, j] = np.median(window)

    return filtered


def mean_filter(image, kernel_size=3):
    """Apply mean filter"""
    pad = kernel_size // 2
    padded = np.pad(image, pad, mode='edge')
    filtered = np.zeros_like(image)

    for i in range(image.shape[0]):
        for j in range(image.shape[1]):
            window = padded[i:i+kernel_size, j:j+kernel_size]
            filtered[i, j] = np.mean(window)

    return filtered

def bilateral_filter(image,d,sigmaColor,sigmaSpace):
    return cv2.bilateralFilter(image,d, sigmaColor, sigmaSpace)


# -----------------------------
# Main Pipeline
# -----------------------------

def main():
    # Create results folder
    os.makedirs("results", exist_ok=True)

    # Load image
    image = load_image("lena.jpeg")

    # Apply noise
    sp_noise = salt_pepper_noise(image, 0.05)
    gauss_noise = gaussian_noise(image, 0, 10)

    # Apply filters
    median_filtered = median_filter(sp_noise, 3)
    mean_filtered = mean_filter(gauss_noise, 3)
    bilateral_filtered = bilateral_filter(gauss_noise.astype(np.float32), 5, 50, 30)

    # Save results
    save_image("results/original.png", image)
    save_image("results/salt_pepper.png", sp_noise)
    save_image("results/median_filtered.png", median_filtered)
    save_image("results/gaussian_noise.png", gauss_noise)
    save_image("results/mean_filtered.png", mean_filtered)
    save_image("results/bilateral_filter.png",bilateral_filtered)

    # Plot results
    plt.figure(figsize=(10, 6))

    plt.subplot(3, 3, 1)
    plt.title("Original")
    plt.imshow(image, cmap='gray')

    plt.subplot(3, 3, 2)
    plt.title("Salt & Pepper")
    plt.imshow(sp_noise, cmap='gray')

    plt.subplot(3, 3, 3)
    plt.title("Median Filter")
    plt.imshow(median_filtered, cmap='gray')

    plt.subplot(3, 3, 4)
    plt.title("Gaussian Noise")
    plt.imshow(gauss_noise, cmap='gray')

    plt.subplot(3, 3, 5)
    plt.title("Mean Filter")
    plt.imshow(mean_filtered, cmap='gray')
    
    plt.subplot(3,3,6)
    plt.title("Bilateral filter")
    plt.imshow(bilateral_filtered,cmap='gray')

    plt.tight_layout()
    plt.show()


if __name__ == "__main__":
    main()
